---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackgroundLayer from '../../components/global/BackgroundLayer.astro';
import BlurText from '../../components/effects/BlurText.astro';
import TrueFocus from '../../components/effects/TrueFocus.astro';
import TiltedCard from '../../components/effects/TiltedCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('portfolio');
projects.sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout>
  <BackgroundLayer slot="bg-layer" section="works" />
  <section class="page-section">
    <div class="container">
      <BlurText as="h1" class="page-title">作品集</BlurText>
      <p class="page-desc reveal">一些自己做过的项目。</p>

      <div class="filter-bar reveal">
        <button class="filter-tag active" data-filter="all">全部</button>
        <button class="filter-tag" data-filter="开源项目">开源项目</button>
        <button class="filter-tag" data-filter="独立开发">独立开发</button>
      </div>

      <TrueFocus class="masonry" blurAmount="2.5px">
        {projects.map(project => (
          <a href={`/portfolio/${project.id}`} class="card project-card" data-category={project.data.category}>
            <TiltedCard maxTilt="6">
              <p class="work-meta">{project.data.year} &middot; {project.data.category}</p>
              <h3 class="work-title">{project.data.title}</h3>
              <p class="work-desc">{project.data.description}</p>
              <div class="work-tags">
                {project.data.techStack.map(tech => <span class="badge">{tech}</span>)}
              </div>
            </TiltedCard>
          </a>
        ))}
      </TrueFocus>
    </div>
  </section>
</BaseLayout>

<style>
  .page-section { padding: 160px 0 var(--space-2xl); position: relative; z-index: 1; }
  .page-desc { font-size: 1.05rem; color: var(--color-text-dim); margin-bottom: var(--space-lg); }
  .filter-bar { display: flex; gap: 10px; margin-bottom: var(--space-lg); flex-wrap: wrap; }
  .filter-tag {
    padding: 6px 16px; font-family: var(--font-mono); font-size: 0.75rem;
    color: var(--color-text-dim); background: transparent; border: 1px solid var(--color-border);
    border-radius: 9999px; cursor: pointer; transition: all 0.3s ease;
  }
  .filter-tag:hover, .filter-tag.active { color: var(--color-accent); border-color: var(--color-accent-dim); }
  .masonry { columns: 2; column-gap: 4px; }
  .project-card {
    break-inside: avoid; margin-bottom: 4px; text-decoration: none; color: inherit;
    display: block; opacity: 1; transform: scale(1); transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .project-card.hidden { opacity: 0; transform: scale(0.95); pointer-events: none; }
  .work-meta { font-size: 0.75rem; font-family: var(--font-mono); color: var(--color-text-faint); margin-bottom: var(--space-sm); letter-spacing: 0.03em; }
  .work-title { font-family: var(--font-heading); font-size: 1.35rem; font-weight: 500; color: var(--color-text); margin-bottom: 10px; letter-spacing: -0.01em; }
  .work-desc { font-size: 0.875rem; color: var(--color-text-dim); line-height: 1.6; }
  .work-tags { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; }
  .badge {
    display: inline-block; padding: 3px 10px; font-family: var(--font-mono);
    font-size: 0.6875rem; color: var(--color-accent-dim); border: 1px solid var(--color-border);
    border-radius: 9999px; transition: all 0.3s ease;
  }
  @media (max-width: 768px) { .masonry { columns: 1; } }
</style>

<script>
  var filterTags = document.querySelectorAll('.filter-tag');
  var projectCards = document.querySelectorAll('.project-card');
  function filterProjects(category) {
    projectCards.forEach(function(card) {
      if (category === 'all' || card.getAttribute('data-category') === category) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  }
  filterTags.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterTags.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      filterProjects(btn.getAttribute('data-filter'));
    });
  });
</script>

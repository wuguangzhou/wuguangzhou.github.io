---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackgroundLayer from '../../components/global/BackgroundLayer.astro';
import BlurText from '../../components/effects/BlurText.astro';
import TrueFocus from '../../components/effects/TrueFocus.astro';
import TiltedCard from '../../components/effects/TiltedCard.astro';
---

<BaseLayout>
  <BackgroundLayer slot="bg-layer" section="works" />

  <section class="page-section">
    <div class="container">
      <BlurText as="h1" class="page-title">作品集</BlurText>
      <p class="page-desc reveal">一些自己做过的项目。</p>

      <div class="filter-bar reveal">
        <button class="filter-tag active" data-filter="all">全部</button>
        <button class="filter-tag" data-filter="opensource">开源项目</button>
        <button class="filter-tag" data-filter="indie">独立开发</button>
      </div>

      <TrueFocus class="masonry" blurAmount="2.5px">
        <a href="/portfolio/flow-editor" class="card project-card" data-category="opensource">
          <TiltedCard maxTilt="6">
            <p class="work-meta">2024 &middot; 开源项目</p>
            <h3 class="work-title">Flow Editor</h3>
            <p class="work-desc">一个轻量级的流程图编辑器，支持实时协作。基于 Canvas API 构建，支持导出为标准格式。</p>
            <div class="work-tags">
              <span class="badge">TypeScript</span>
              <span class="badge">React</span>
              <span class="badge">Canvas</span>
            </div>
          </TiltedCard>
        </a>
        <a href="/portfolio/minimal-log" class="card project-card" data-category="indie">
          <TiltedCard maxTilt="6">
            <p class="work-meta">2023 &middot; 独立开发</p>
            <h3 class="work-title">Minimal Log</h3>
            <p class="work-desc">极简风格的日志聚合与可视化工具。单个二进制文件，零配置启动。</p>
            <div class="work-tags">
              <span class="badge">Go</span>
              <span class="badge">HTMX</span>
              <span class="badge">SQLite</span>
            </div>
          </TiltedCard>
        </a>
        <a href="/portfolio/ink-notes" class="card project-card" data-category="indie">
          <TiltedCard maxTilt="6">
            <p class="work-meta">2023 &middot; 独立开发</p>
            <h3 class="work-title">Ink Notes</h3>
            <p class="work-desc">一个支持 Markdown 的极简私人笔记应用。本地存储，零数据泄露。</p>
            <div class="work-tags">
              <span class="badge">Rust</span>
              <span class="badge">Tauri</span>
              <span class="badge">Markdown</span>
            </div>
          </TiltedCard>
        </a>
      </TrueFocus>
    </div>
  </section>
</BaseLayout>

<style>
  .page-section {
    padding: 160px 0 var(--space-2xl);
    position: relative;
    z-index: 1;
  }
  .filter-bar {
    display: flex;
    gap: 10px;
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
  }
  .filter-tag {
    padding: 6px 16px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .filter-tag:hover,
  .filter-tag.active {
    color: var(--color-accent);
    border-color: var(--color-accent-dim);
  }

  .masonry {
    columns: 2;
    column-gap: 4px;
  }
  .project-card {
    break-inside: avoid;
    margin-bottom: 4px;
    text-decoration: none;
    color: inherit;
    display: block;
    opacity: 1;
    transform: scale(1);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .project-card.hidden {
    opacity: 0;
    transform: scale(0.95);
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .masonry {
      columns: 1;
    }
  }
</style>

<script>
  var filterTags = document.querySelectorAll('.filter-tag');
  var projectCards = document.querySelectorAll('.project-card');

  function filterProjects(category) {
    projectCards.forEach(function(card) {
      if (category === 'all' || card.getAttribute('data-category') === category) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  }

  filterTags.forEach(function(btn) {
    btn.addEventListener('click', function() {
      filterTags.forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      filterProjects(btn.getAttribute('data-filter'));
    });
  });
</script>

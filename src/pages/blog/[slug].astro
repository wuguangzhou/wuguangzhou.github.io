---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackgroundLayer from '../../components/global/BackgroundLayer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const posts = await getCollection('blog');
const post = posts.find(p => p.id === slug);
if (!post) throw new Error('Post not found: ' + slug);

// 手動渲染 Markdown 正文（Astro v7 的 getCollection 条目无 render 方法）
const bodyHtml = post.body
  ? post.body.replace(/^---[\s\S]*?---\n*/, '').split('\n\n').map((p: string) => `<p>${p.trim().replace(/\n/g, '<br>')}</p>`).join('')
  : '';

// 上一页 / 下一页
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const idx = sorted.findIndex(p => p.id === slug);
const prev = idx < sorted.length - 1 ? sorted[idx + 1] : null;
const next = idx > 0 ? sorted[idx - 1] : null;
---

<BaseLayout>
  <BackgroundLayer slot="bg-layer" section="blog" />
  <article class="page-section">
    <div class="container">
      <a href="/blog" class="back-link reveal">&larr; 返回博客</a>
      <h1 class="detail-title reveal">{post.data.title}</h1>
      <div class="detail-meta reveal">
        <time>{post.data.date.toISOString().slice(0, 10)}</time>
        <span>&middot;</span>
        <span>约 {Math.ceil(post.body?.length / 500 || 3)} 分钟阅读</span>
        {post.data.tags.length > 0 && (
          <><span>&middot;</span><span>{post.data.tags.join('、')}</span></>
        )}
      </div>
      <div class="prose reveal" set:html={bodyHtml} />
      <nav class="detail-nav reveal">
        {prev ? <a href={`/blog/${prev.id}`} class="text-link">&larr; {prev.data.title}</a> : <span />}
        {next ? <a href={`/blog/${next.id}`} class="text-link">{next.data.title} &rarr;</a> : <span />}
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .page-section { padding: 160px 0 var(--space-2xl); position: relative; z-index: 1; }
  .back-link { font-size: 0.875rem; color: var(--color-text-dim); text-decoration: none; display: inline-block; margin-bottom: var(--space-lg); transition: color 0.3s ease; }
  .back-link:hover { color: var(--color-accent); }
  .detail-title { font-family: var(--font-heading); font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 600; letter-spacing: -0.02em; color: var(--color-text); margin-bottom: var(--space-sm); }
  .detail-meta { font-size: 0.875rem; font-family: var(--font-mono); color: var(--color-text-faint); margin-bottom: var(--space-xl); display: flex; gap: 0.4em; flex-wrap: wrap; }
  .prose { font-size: 1rem; line-height: 1.8; color: var(--color-text-dim); max-width: 680px; margin-bottom: var(--space-xl); }
  .prose :global(p) { margin-bottom: 1.2em; }
  .detail-nav { display: flex; justify-content: space-between; padding-top: var(--space-lg); border-top: 1px solid var(--color-border); }
  @media (max-width: 768px) { .detail-nav { flex-direction: column; gap: var(--space-sm); } }
</style>
